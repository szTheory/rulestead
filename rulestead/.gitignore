# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where generated docs are written.
/doc/

# Ignore .fetch files in case dependencies are edited locally.
/.fetch

# Also ignore archive artifacts.
/*.ez

# Ignore generated package tarballs.
/rulestead-*.tar

# Dialyzer PLTs — local/CI cache artifacts, not source.
/priv/plts/

# Stray captured command/test output dumps.
/output.txt
