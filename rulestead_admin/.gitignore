# The directory Mix will write compiled artifacts to.
/_build/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where generated docs are written.
/doc/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# Ignore .fetch files in case dependencies are edited locally.
/.fetch

# Also ignore archive artifacts.
/*.ez

# Ignore generated package tarballs.
/rulestead_admin-*.tar

# Local debugging scratch output.
/debug_out.txt
/form_failures.txt
/test_failures.txt

# mix phx.digest output — generated fingerprinted assets and manifests.
/priv/static/cache_manifest.json
/priv/static/**/*.gz
/priv/static/css/*-*.css
/priv/static/images/*-*.svg
!/priv/static/images/rs-wordmark.svg
!/priv/static/images/rs-wordmark-dark.svg
/priv/static/*-*.html
