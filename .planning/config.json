{
  "model_profile": "balanced",
  "commit_docs": true,
  "parallelization": true,
  "search_gitignored": false,
  "brave_search": false,
  "firecrawl": false,
  "exa_search": false,
  "git": {
    "branching_strategy": "none",
    "phase_branch_template": "gsd/phase-{phase}-{slug}",
    "milestone_branch_template": "gsd/{milestone}-{slug}",
    "quick_branch_template": null
  },
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true,
    "auto_advance": true,
    "node_repair": true,
    "node_repair_budget": 2,
    "ui_phase": true,
    "ui_safety_gate": true,
    "text_mode": true,
    "research_before_questions": true,
    "discuss_mode": "assumptions",
    "skip_discuss": false,
    "code_review": true,
    "code_review_depth": "standard",
    "milestone_next_step": {
      "adopter_lens": true,
      "parallel_repo_research": true,
      "retain_threads_and_retrospective": true,
      "prompts_dir": "prompts/",
      "path_to_done_thread": true
    },
    "milestone_assessment": {
      "run_at_new_milestone": true,
      "prefer_repo_inspection_over_docs": true,
      "adopter_lens_default": true,
      "no_auto_new_milestone": true,
      "verify_lib_before_scope": true,
      "stop_milestone_includes_release_truth": true,
      "jtbd_refresh_at_milestone_close": true,
      "flag_conformance_manifest_drift": true
    },
    "_auto_chain_active": true,
    "use_worktrees": false
  },
  "hooks": {
    "context_warnings": true
  },
  "project_code": null,
  "phase_naming": "sequential",
  "agent_skills": {},
  "features": {},
  "resolve_model_ids": "omit",
  "mode": "yolo",
  "granularity": "standard"
}
